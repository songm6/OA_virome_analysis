#!/bin/bash
#SBATCH --job-name=count
#SBATCH --output=count.%j.out
#SBATCH --error=count.%j.err
#SBATCH --time=4:00:00
#SBATCH --cpus-per-task=1
#SBATCH --mem=32G
#SBATCH --ntasks=1
#SBATCH --mail-user=minseo.song@vanderbilt.edu
#SBATCH --mail-type=BEGIN,END,FAIL

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../config.sh"

mkdir -p "${COUNTS_DIR}"

cat "${VIRAL_ALIGN}"/chunks_mate1/res_second_blast_1_part_*.txt > "${VIRAL_ALIGN}/res_second_blast_1.txt"
cat "${VIRAL_ALIGN}"/chunks_mate2/res_second_blast_2_part_*.txt > "${VIRAL_ALIGN}/res_second_blast_2.txt"

python3 "${COUNT_SCRIPT}" \
  "${VIRAL_ALIGN}/res_second_blast_1.txt" \
  "${VIRAL_ALIGN}/res_second_blast_2.txt" \
  "${EVALUE_THRESHOLD}" \
  "${SAMPLE_ID}" > "${COUNTS_DIR}/count_${SAMPLE_ID}.txt"

echo "Count finished at: $(date)"
