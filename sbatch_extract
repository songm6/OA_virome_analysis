#!/bin/bash
#SBATCH --job-name=extract
#SBATCH --output=extract.%j.out
#SBATCH --error=extract.%j.err
#SBATCH --time=4:00:00
#SBATCH --cpus-per-task=1
#SBATCH --mem=32G
#SBATCH --ntasks=1
#SBATCH --mail-user=minseo.song@vanderbilt.edu
#SBATCH --mail-type=BEGIN,END,FAIL

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../config.sh"

python3 "${EXTRACT_SCRIPT}" \
  "${VIRAL_ALIGN}/res_first_blast_1.txt" \
  "${UNMAPPED_DIR}/${SAMPLE_ID}_unmapped_1.fas" \
  > "${VIRAL_ALIGN}/viral_hit_fasta_1.fas"

python3 "${EXTRACT_SCRIPT}" \
  "${VIRAL_ALIGN}/res_first_blast_2.txt" \
  "${UNMAPPED_DIR}/${SAMPLE_ID}_unmapped_2.fas" \
  > "${VIRAL_ALIGN}/viral_hit_fasta_2.fas"

echo "Extract finished at: $(date)"
