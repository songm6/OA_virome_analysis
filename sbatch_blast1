#!/bin/bash
#SBATCH --job-name=blast1
#SBATCH --output=blast1.%j.out
#SBATCH --error=blast1.%j.err
#SBATCH --time=96:00:00
#SBATCH --cpus-per-task=8
#SBATCH --mem=64G
#SBATCH --ntasks=1
#SBATCH --mail-user=minseo.song@vanderbilt.edu
#SBATCH --mail-type=BEGIN,END,FAIL

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../config.sh"

module load blast+/2.17.0

mkdir -p "${VIRAL_ALIGN}"

if [ ! -f "${FIRST_BLAST_DB}.nhr" ]; then
  makeblastdb -in "${VIRUS_FA}" -dbtype nucl -out "${FIRST_BLAST_DB}"
fi

blastn -db "${FIRST_BLAST_DB}" \
  -query "${UNMAPPED_DIR}/${SAMPLE_ID}_unmapped_1.fas" \
  -out "${VIRAL_ALIGN}/res_first_blast_1.txt" \
  -word_size 11 -outfmt 6 -num_threads 8

blastn -db "${FIRST_BLAST_DB}" \
  -query "${UNMAPPED_DIR}/${SAMPLE_ID}_unmapped_2.fas" \
  -out "${VIRAL_ALIGN}/res_first_blast_2.txt" \
  -word_size 11 -outfmt 6 -num_threads 8

echo "First BLAST finished at: $(date)"
